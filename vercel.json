{
  "version": 2,
  "name": "sim-vein",

  "headers": [
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" },
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/:all*.(js|css|png|svg|jpg|jpeg|gif|webp|ico|txt|json|map)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],

  "routes": [
    { "src": "^/$", "dest": "/index.html" },
    {
      "src": "^(?!.*\\.(?:js|css|png|svg|jpg|jpeg|gif|webp|ico|txt|json|webmanifest|map)$).*$",
      "dest": "/index.html"
    }
  ]
}
